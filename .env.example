# Runtime
NODE_ENV=development

# Primary LLM provider (Gemini)
GEMINI_API_KEY=
# Optional alias used by some Genkit integrations
GOOGLE_GENAI_API_KEY=

# Fallback AI providers
GROQ_API_KEY=
MISTRAL_API_KEY=
HUGGINGFACE_API_KEY=

# Google Earth Engine / Firebase Admin credentials JSON (single-line JSON string)
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Phase 3 (GCP serverless orchestration)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1
GCP_PIPELINE_TOPIC_PREFIX=earth-insights.pipeline
GCP_MONTHLY_BUDGET_USD=1200
GCP_DAILY_RUN_QUOTA=6

# Supabase Configurations
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-ID].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=[YOUR-PUBLISHABLE-KEY]
SUPABASE_SERVICE_ROLE_KEY=[YOUR-SECRET-SERVICE-ROLE-KEY]

# Database & Cache (Redesign Phase - Supabase)
# DATABASE_URL: Transaction pooled connection string (port 6543, mode=transaction)
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[YOUR-REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL: Direct database connection string for migrations (port 5432)
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[YOUR-REGION].pooler.supabase.com:5432/postgres"

REDIS_URL="redis://localhost:6379"
